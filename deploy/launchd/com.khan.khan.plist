<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.khan.khan</string>
  <key>ProgramArguments</key>
  <array>
    <string>__KHAN_BIN__</string>
    <string>daemon</string>
    <string>run</string>
    <string>--config</string>
    <string>__KHAN_CONFIG__</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>KHAN_HOME</key>
    <string>__KHAN_HOME__</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>WorkingDirectory</key>
  <string>__KHAN_WORKDIR__</string>
  <key>StandardOutPath</key>
  <string>__KHAN_LOG_DIR__/khan.out.log</string>
  <key>StandardErrorPath</key>
  <string>__KHAN_LOG_DIR__/khan.err.log</string>
</dict>
</plist>
